# Neon PostgreSQL connection string
# Get this from the Neon console: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Langfuse LLM Observability
# Get these from: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Google Gemini API (AI SDK)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# AI Provider Selection (gemini or groq)
# Default: gemini
AI_PROVIDER=gemini

# Groq API Key (required when AI_PROVIDER=groq)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=
